{
  "name": "tokyo-geek",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "vitepress build docs",
    "check": "pnpm run lint && vitepress dev docs",
    "code-format": "prettier --write .",
    "dev": "vitepress dev docs",
    "format-code": "prettier --write .",
    "format-md": "markdownlint-cli2",
    "format-shell": "shfmt -w .",
    "help-me": "zsh scripts/help-me.sh",
    "lint-md": "pnpm run format-code && pnpm run format-md",
    "lint": "pnpm run format-code && pnpm run format-md && pnpm run format-shell",
    "preview": "vitepress preview docs",
    "test": "pnpm run lint && vitepress build docs && vitepress preview docs",
    "tree": "node scripts/generate-doc-structure.mjs"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@davidingplus/vitepress-image-viewer": "^1.1.5",
    "@nolebase/vitepress-plugin-enhanced-readabilities": "^2.18.2",
    "@nolebase/vitepress-plugin-meta": "^2.18.2",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vite-pwa/vitepress": "^1.1.0",
    "gray-matter": "^4.0.3",
    "init": "^0.1.2",
    "js-yaml": "^4.1.1",
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli2": "^0.22.0",
    "markdownlint-rule-search-replace": "^1.2.0",
    "openai": "^6.32.0",
    "prettier": "^3.8.1",
    "shfmt": "^0.0.1",
    "tree-extended": "^4.6.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite": "^8.0.2",
    "vitepress-mermaid-renderer": "^1.1.19",
    "vitepress-sidebar": "^1.33.1",
    "vitepress": "2.0.0-alpha.16",
    "vue": "^3.5.30"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  }
}
