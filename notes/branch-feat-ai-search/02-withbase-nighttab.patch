 <<< @/public/share/nighttab/travel-bookmarks.json
 
@@ -105,7 +105,7 @@ Here is a nightTab setup to quickly access various streaming services.
 
 <!-- markdownlint-disable MD033 -->
 <details>
-  <summary>Click to expand <a href="/public/share/nighttab/streaming-bookmarks.json">streaming-bookmarks.json</a></summary>
+  <summary>Click to expand <a :href="withBase('/public/share/nighttab/streaming-bookmarks.json')">streaming-bookmarks.json</a></summary>
 
 <<< @/public/share/nighttab/streaming-bookmarks.json
 
@@ -137,3 +137,9 @@ Here is a nightTab setup to quickly access various streaming services.
 [firefox-homepage]: https://github.com/zombieFox/nightTab/wiki/Setting-nightTab-as-your-Firefox-homepage
 [protected-urls]: https://github.com/zombieFox/nightTab/wiki/Protected-URLs
 [no-image]: https://github.com/zombieFox/nightTab/wiki/Local-background-image
+
+<!-- markdownlint-disable MD033 -->
+<script setup>
+import { withBase } from 'vitepress'
+</script>
+<!-- markdownlint-enable MD033 -->
