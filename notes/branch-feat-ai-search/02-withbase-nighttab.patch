diff --git a/docs/en/tech/nighttab.md b/docs/en/tech/nighttab.md
index fefc687..be028df 100644
--- a/docs/en/tech/nighttab.md
+++ b/docs/en/tech/nighttab.md
@@ -79,7 +79,7 @@ Here is a nightTab setup to quickly access various Google products.
 
 <!-- markdownlint-disable MD033 -->
 <details>
-  <summary>Click to expand <a href="/public/share/nighttab/google-bookmarks.json">google-bookmarks.json</a></summary>
+  <summary>Click to expand <a :href="withBase('/public/share/nighttab/google-bookmarks.json')">google-bookmarks.json</a></summary>
 
 <<< @/public/share/nighttab/google-bookmarks.json
 
@@ -92,7 +92,7 @@ Here is a nightTab setup to quickly access travel-related bookmarks.
 
 <!-- markdownlint-disable MD033 -->
